/**
 * This ruleset enforces a hybrid security model for an accounting ERP system.
 * It combines global administrator roles, a user-ownership model for personal data,
 * and a collaborative access model for company-specific data.
 *
 * Core Philosophy:
 * The default posture is deny-all. Access is granted explicitly based on a user's
 * identity and their relationship to the data they are trying to access. Global
 * administrators have broad read access for oversight and specific write access
 * for managing core entities like companies and user roles.
 *
 * Data Structure:
 * - /users/{userId}: Private user profile data, accessible only by the owner and admins.
 * - /companies/{companyId}: Top-level documents for each client company. These
 *   contain a denormalized `members` map to control access.
 * - /companies/{companyId}/{subcollection}: Nested data like documents, tax obligations,
 *   and corporate processes inherit their access rights from the parent company's
 *   `members` map.
 *
 * Key Security Decisions:
 * - Admin Rights: Admin privileges are determined by the `permissions.usuarios.update`
 *   flag within a user's profile document.
 * - Company Access: All access to a company's data and its subcollections is
 *   controlled by a `members` map denormalized directly onto the company document.
 *   This avoids slow and costly `get()` calls across different collections in rules.
 * - User Data Privacy: Users can only access their own document within the `/users`
 *   collection. Listing all users is prohibited for non-admins.
 * - Creator-Based Write Rules: Within a company's subcollections, any member can
 *   create new documents (e.g., upload a file), but only the original creator
 *   (or an admin) can modify or delete them.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper Functions
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
        
    function hasPermission(module, permission) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && getUserProfile(request.auth.uid).permissions[module][permission] == true;
    }

    function isAdmin() {
      return hasPermission('usuarios', 'update');
    }

    function isCompanyMember(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data.members[request.auth.uid] != null;
    }

    function isCompanyAdminOnResource() {
      return resource.data.members[request.auth.uid] == 'admin';
    }

    function canReadCompanyData(companyId) {
      return isAdmin() || isCompanyMember(companyId);
    }
    
    function isCreatingOwnCompany() {
      return isSignedIn() && request.resource.data.members[request.auth.uid] == 'admin';
    }

    function isExistingResponsibleUserOrAdmin() {
      return resource != null && (isAdmin() || isOwner(resource.data.responsibleUserId));
    }

    // =========================================================================
    // Rules
    // =========================================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('usuarios', 'read');
      allow list: if hasPermission('usuarios', 'read');
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || hasPermission('usuarios', 'update');
      allow delete: if hasPermission('usuarios', 'delete') && request.auth.uid != userId;
    }

    match /companies/{companyId} {
      allow get: if canReadCompanyData(companyId);
      allow list: if isSignedIn();
      allow create: if isCreatingOwnCompany();
      allow update: if (isAdmin() || isCompanyMember(companyId)) && resource != null;
      allow delete: if (isAdmin() || isCompanyMember(companyId)) && resource != null;

      match /certificates/{certificateId} {
        allow read: if hasPermission('empresas', 'read');
        allow write: if hasPermission('empresas', 'update');
      }

      match /taxObligations/{taxObligationId} {
        allow read: if hasPermission('obrigacoes', 'read');
        allow create: if hasPermission('obrigacoes', 'create');
        allow update: if hasPermission('obrigacoes', 'update');
        allow delete: if hasPermission('obrigacoes', 'delete');
      }

      match /documents/{documentId} {
        allow read: if hasPermission('documentos', 'read');
        allow create: if hasPermission('documentos', 'create');
        allow update: if hasPermission('documentos', 'update');
        allow delete: if hasPermission('documentos', 'delete');
      }
    }
    
    match /partners/{partnerId} {
        allow read, write: if isSignedIn();
    }
    
    match /invoices/{invoiceId} {
        allow read: if hasPermission('financeiro', 'read');
        allow create: if hasPermission('financeiro', 'create');
        allow update: if hasPermission('financeiro', 'update');
        allow delete: if hasPermission('financeiro', 'delete');
    }
    
    match /fiscalDocuments/{documentId} {
      allow read: if hasPermission('fiscal', 'read');
      allow create: if hasPermission('fiscal', 'create');
      allow update: if hasPermission('fiscal', 'update');
      allow delete: if hasPermission('fiscal', 'delete');

      match /notes/{noteId} {
        allow read: if hasPermission('fiscal', 'read');
        allow create: if hasPermission('fiscal', 'create');
        allow update, delete: if hasPermission('fiscal', 'update') && isOwner(resource.data.userId);
      }
    }

    match /xmlStatus/{statusId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('fiscal', 'update');
    }

    match /activities/{activityId} {
        allow read, create: if isSignedIn();
        allow update, delete: if false;
    }

     match /corporateProcesses/{processId} {
        allow read: if hasPermission('processos', 'read');
        allow create: if hasPermission('processos', 'create');
        allow update: if hasPermission('processos', 'update');
        allow delete: if hasPermission('processos', 'delete');

        match /history/{historyId} {
            allow read, write: if hasPermission('processos', 'update');
        }
        match /attachments/{attachmentId} {
            allow read, write: if hasPermission('processos', 'update');
        }
    }
  }
}
